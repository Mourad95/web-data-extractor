{
  "manifest_version": 3,
  "name": "Web Data Extractor",
  "description": "Extract text and attributes from web pages with custom CSS selectors.",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "webRequest", "debugger"],
  "host_permissions": ["https://*/*", "http://*/*", "http://localhost/*", "ws://localhost/*"],
  "action": {
    "default_title": "Web Data Extractor",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
